# =============================================================================
# Bot Identity
# =============================================================================
BOT_NAME="MyBot"           # Display name (e.g., "Jarvis", "Alfred")
BOT_USER=mybot             # Linux username the bot runs as
BOT_EMOJI=🤖               # Bot's emoji identity

# =============================================================================
# User Info
# =============================================================================
USER_NAME="Your Name"      # e.g., "Wade Watts"
USER_TIMEZONE=UTC           # e.g., MST, EST, PST, UTC
USER_LOCATION="City, State" # e.g., "Oklahoma City, OK"
USER_EMAIL=you@example.com

# =============================================================================
# Required: OpenAI Codex tokens
#
# Requires a ChatGPT Plus, Pro, or Business subscription.
#
# To obtain tokens:
#   1. As the bot user (fresh SSH session), run:
#        openclaw onboard --auth-choice openai-codex --skip-daemon
#   2. Complete the OAuth flow in your browser.
#   3. Extract tokens and paste them below:
#        jq -r '.profiles["openai-codex:default"].access' ~/.openclaw/agents/main/agent/auth-profiles.json
#        → paste output into OPENAI_ACCESS_TOKEN
#        jq -r '.profiles["openai-codex:default"].refresh' ~/.openclaw/agents/main/agent/auth-profiles.json
#        → paste output into OPENAI_REFRESH_TOKEN
# =============================================================================
OPENAI_ACCESS_TOKEN=       # JWT access token (~8 day lifespan)
OPENAI_REFRESH_TOKEN=      # Refresh token (rt_* prefix, ~60 day lifespan)

# =============================================================================
# Optional: Telegram
# Leave blank to skip Telegram setup.
# =============================================================================
TELEGRAM_BOT_TOKEN=        # From @BotFather on Telegram
TELEGRAM_USER_ID=          # Your numeric Telegram user ID (from @userinfobot)

# =============================================================================
# Optional: Brave Search
# Enables web search. Free tier: 2000 queries/month.
# Get a key at: brave.com/search/api
# Leave blank to disable web search.
# =============================================================================
BRAVE_SEARCH_KEY=

# =============================================================================
# Optional: Slack
# Openclaw supports Slack natively, but this toolkit doesn't auto-configure it.
# To use Slack, fill these in and then manually add the Slack connection to
# openclaw.json after running setup.sh. See README.md for details.
# =============================================================================
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# =============================================================================
# Gateway
#
# GATEWAY_PORT must be unique per bot user on a shared server.
# Convention: first user 18789, second 18790, third 18791, etc.
# Check what's already in use: ss -tuln | grep :187
#
# GATEWAY_TOKEN is the password for the web dashboard. If left blank, a random
# 48-char hex token is generated during setup. Save it back to .env after the
# first run so the dashboard URL stays the same on re-runs.
# =============================================================================
GATEWAY_PORT=18789
GATEWAY_TOKEN=

# =============================================================================
# gog (Google Workspace CLI)
# Encrypts Google OAuth tokens stored locally. Any value works.
# Default "redbot" is fine — change it if you want a custom passphrase.
# =============================================================================
GOG_KEYRING_PASSWORD=redbot
